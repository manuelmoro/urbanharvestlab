---
import { getCollection } from 'astro:content';

import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categories } from '../../data/categories';
import { getFeaturedPosts, getPublishedPosts } from '../../utils/content';
import { blogIndexPath, getCategoryPath } from '../../utils/seo';

const allPosts = getPublishedPosts(await getCollection('blog'));
const featuredPosts = getFeaturedPosts(allPosts).slice(0, 3);
---

<BaseLayout
  title="Urban Gardening, Hydroponics, and Indoor Growing Guides"
  description="Browse every Urban Harvest Lab article on urban gardening, hydroponics, grow lights, containers, soil, and plant troubleshooting."
  canonicalPath={blogIndexPath}
>
  <section class="page-section">
    <div class="container page-hero">
      <div class="page-hero__panel">
        <span class="eyebrow">Browse the guides</span>
        <h1>Browse practical guides for small-space growing.</h1>
        <p>
          Start with a broad setup guide, jump into a topic hub, or go straight to the problem you need to solve now.
        </p>
      </div>
    </div>

    <div class="container">
      <div class="section-heading section-heading--compact">
        <span class="eyebrow">Featured reads</span>
        <h2>Good places to start.</h2>
      </div>

      <div class="card-grid card-grid--three">
        {featuredPosts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">All articles</span>
        <h2>All guides</h2>
        <p>
          Browse every article or jump into a category:
          {
            categories.map((category, index) => (
              <>
                {' '}
                <a href={getCategoryPath(category.slug)}>{category.shortTitle}</a>
                {index < categories.length - 1 ? ',' : '.'}
              </>
            ))
          }
        </p>
      </div>

      <div class="card-grid">
        {allPosts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>
</BaseLayout>
