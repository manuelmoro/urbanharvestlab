---
import { getCollection } from 'astro:content';

import CategoryCard from '../../components/CategoryCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categories } from '../../data/categories';
import { getPublishedPosts } from '../../utils/content';
import { categoriesIndexPath } from '../../utils/seo';

const allPosts = getPublishedPosts(await getCollection('blog'));
const categoryCounts = new Map(categories.map((category) => [category.slug, 0]));

for (const post of allPosts) {
  categoryCounts.set(post.data.category, (categoryCounts.get(post.data.category) ?? 0) + 1);
}
---

<BaseLayout
  title="Topic Hubs for Urban Gardening, Hydroponics, and Indoor Growing"
  description="Browse Urban Harvest Lab topic hubs for urban gardening, hydroponics, grow lights, containers, soil, and plant troubleshooting."
  canonicalPath={categoriesIndexPath}
>
  <section class="page-section">
    <div class="container page-hero">
      <div class="page-hero__panel">
        <span class="eyebrow">Categories</span>
        <h1>Browse the main topic hubs for small-space growing.</h1>
        <p>
          Each hub is built as the primary landing page for a topic, with clearer entry points than a plain article
          archive.
        </p>
      </div>
    </div>

    <div class="container category-grid">
      {categories.map((category) => <CategoryCard category={category} count={categoryCounts.get(category.slug) ?? 0} />)}
    </div>
  </section>
</BaseLayout>
