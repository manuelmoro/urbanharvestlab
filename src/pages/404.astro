---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you requested could not be found." noIndex>
  <section class="page-section">
    <div class="container page-hero">
      <div class="page-hero__panel">
        <span class="eyebrow">404</span>
        <h1>The page you requested is not here.</h1>
        <p>Try the main blog index or browse the category hubs to get back into the site.</p>
        <div class="button-row">
          <a class="button button--primary" href="/blog/">Go to blog</a>
          <a class="button button--secondary" href="/categories/">Browse categories</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
