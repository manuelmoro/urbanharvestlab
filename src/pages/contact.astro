---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout
  title="Contact"
  description="Contact Urban Harvest Lab for questions, partnerships, corrections, and general enquiries."
  canonicalPath="/contact/"
>
  <section class="page-section">
    <div class="container page-hero">
      <div class="page-hero__panel">
        <span class="eyebrow">Contact</span>
        <h1>Questions, corrections, and partnership enquiries.</h1>
        <p>
          Email is the best way to reach Urban Harvest Lab. Use the details below for feedback, corrections, or
          business conversations.
        </p>
      </div>
    </div>

    <div class="container contact-grid">
      <article class="card">
        <span class="eyebrow">Primary email</span>
        <h2>{site.email}</h2>
        <p>
          For general enquiries, feedback, and article corrections, email <a href={`mailto:${site.email}`}>{site.email}</a>.
        </p>
        <div class="button-row" style="margin-top: 1rem;">
          <a class="button button--primary" href={`mailto:${site.email}?subject=Urban%20Harvest%20Lab%20enquiry`}>
            Write an email
          </a>
        </div>
      </article>

      <article class="card">
        <span class="eyebrow">What to include</span>
        <h2>Make the message easy to action</h2>
        <p>
          Include the page URL, the issue you noticed, and any product or growing context that matters. Specific
          details make corrections and responses much faster.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
