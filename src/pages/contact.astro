---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout
  title="Contact"
  description="Contact Urban Harvest Lab for editorial questions, partnerships, corrections, and general enquiries."
  canonicalPath="/contact/"
>
  <section class="page-section">
    <div class="container page-hero">
      <div class="page-hero__panel">
        <span class="eyebrow">Contact</span>
        <h1>Editorial questions, corrections, and partnership enquiries.</h1>
        <p>
          The site is built for publishing, not app-style interaction, so the clearest contact method is still email.
          Use the details below for editorial feedback or business conversations.
        </p>
      </div>
    </div>

    <div class="container contact-grid">
      <article class="card">
        <span class="eyebrow">Primary email</span>
        <h2>{site.email}</h2>
        <p>
          For general enquiries, feedback, and article corrections, email <a href={`mailto:${site.email}`}>{site.email}</a>.
        </p>
      </article>

      <article class="card">
        <span class="eyebrow">What to include</span>
        <h2>Make the message easy to action</h2>
        <p>
          Include the page URL, the issue you noticed, and any product or growing context that matters. Specific
          details make corrections and responses much faster.
        </p>
      </article>
    </div>

    <div class="container" style="margin-top: 1rem;">
      <div class="card">
        <span class="eyebrow">Future form integration</span>
        <h2>Contact form placeholder</h2>
        <p>
          This static form is included for layout readiness. Connect it to your preferred email or form backend when
          you are ready to handle submissions directly.
        </p>

        <form class="contact-form" aria-label="Contact form placeholder">
          <input type="text" placeholder="Name" disabled />
          <input type="email" placeholder="Email" disabled />
          <textarea placeholder="Message" disabled></textarea>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
