---
import { getCollection } from 'astro:content';

import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/content.css';
import { categories } from '../../data/categories';
import { site } from '../../data/site';
import { getPostsByCategory, getPublishedPosts } from '../../utils/content';
import { buildBreadcrumbJsonLd, buildCollectionPageJsonLd } from '../../utils/schema';
import { categoriesIndexPath, getCategoryArchivePath, getHubPath } from '../../utils/seo';

export async function getStaticPaths() {
  return categories.map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const allPosts = getPublishedPosts(await getCollection('blog'));
const allHubs = await getCollection('hubs');
const hub = allHubs.find((entry) => entry.data.category === category.slug);
const posts = getPostsByCategory(allPosts, category.slug);
const siteBase = Astro.site ?? site.url;
const archivePath = getCategoryArchivePath(category.slug);
const hubPath = getHubPath(category.slug);
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Categories', href: categoriesIndexPath },
  { label: category.title, href: hubPath },
  { label: 'Article archive' },
];
const breadcrumbJsonLd = buildBreadcrumbJsonLd(breadcrumbItems, archivePath, siteBase);
const categoryJsonLd = buildCollectionPageJsonLd(
  `${category.title} Article Archive`,
  `Plain list of every published ${category.shortTitle.toLowerCase()} guide on Urban Harvest Lab. Use the main topic hub for curated pathways and stronger entry points.`,
  archivePath,
  siteBase,
);
---

<BaseLayout
  title={`${category.title} Article Archive`}
  description={`Plain list of every published ${category.shortTitle.toLowerCase()} guide on Urban Harvest Lab. Use the main topic hub for curated pathways and stronger entry points.`}
  canonicalPath={archivePath}
  noIndex
  jsonLd={[categoryJsonLd, breadcrumbJsonLd]}
>
  <section class="page-section">
    <div class="container page-hero">
      <div class="page-hero__panel">
        <Breadcrumbs items={breadcrumbItems} />
        <span class="eyebrow">Article archive</span>
        <h1>{category.title} article archive</h1>
        <p>
          This is the plain utility list for every published {category.shortTitle.toLowerCase()} guide. For the main
          topic page with curated pathways, featured entry points, and broader context, use the primary hub.
        </p>
      </div>
    </div>

    {
      hub ? (
        <div class="container">
          <div class="category-hub-preview">
            <div class="card">
              <span class="eyebrow">Primary topic hub</span>
              <h2>{hub.data.title}</h2>
              <p>{hub.data.overview}</p>
              <div class="button-row">
                <a class="button button--primary" href={hubPath}>Open topic hub</a>
                <a class="button button--secondary" href="#category-guides">Jump to the archive list</a>
              </div>
            </div>
          </div>
        </div>
      ) : null
    }
  </section>

  <section class="page-section" id="category-guides">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">{posts.length} {posts.length === 1 ? 'article' : 'articles'}</span>
        <h2>All published {category.shortTitle.toLowerCase()} guides</h2>
        <p>
          Browse the full set of published guides in {category.title}. This archive stays intentionally simple so it
          does not compete with the main hub.
        </p>
      </div>

      {posts.length > 0 ? <div class="card-grid">{posts.map((post) => <PostCard post={post} compact />)}</div> : <div class="card"><p>No articles have been published in this category yet.</p></div>}
    </div>
  </section>
</BaseLayout>
