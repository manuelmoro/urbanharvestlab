---
import { site } from '../data/site';

const currentPath = Astro.url.pathname;
const primaryNavigation = site.navigation.filter((item) => item.mobilePriority !== 'secondary');
const secondaryNavigation = site.navigation.filter((item) => item.mobilePriority === 'secondary');
const hasSecondaryCurrent = secondaryNavigation.some((item) => currentPath === item.href);
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label={`${site.name} home`}>
      <span class="brand__mark">UHL</span>
      <span>
        <span class="brand__kicker">Editorial garden lab</span>
        <span class="brand__name">{site.name}</span>
        <span class="brand__tagline">{site.tagline}</span>
      </span>
    </a>

    <nav aria-label="Primary" class="site-nav">
      <div class="site-nav__links site-nav__links--primary">
        {
          primaryNavigation.map((item) => (
            <a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>
              {item.label}
            </a>
          ))
        }
      </div>

      <div class="site-nav__links site-nav__links--secondary">
        {
          secondaryNavigation.map((item) => (
            <a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>
              {item.label}
            </a>
          ))
        }
      </div>

      <details class="site-nav__more" data-current={hasSecondaryCurrent ? 'true' : undefined}>
        <summary aria-label="Open more pages">
          <span></span>
          <span></span>
          <span></span>
        </summary>

        <div class="site-nav__dropdown">
          {
            secondaryNavigation.map((item) => (
              <a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>
                {item.label}
              </a>
            ))
          }
        </div>
      </details>
    </nav>
  </div>
</header>
