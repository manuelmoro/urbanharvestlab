---
import type { CollectionEntry } from 'astro:content';

import PostCard from './PostCard.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

{
  posts.length > 0 ? (
    <section class="popular-guides">
      <div class="section-heading section-heading--split">
        <div>
          <span class="eyebrow">Popular guides</span>
          <h2>Popular guides readers return to often.</h2>
        </div>
        <p>These are strong starting points if you want practical guidance before getting into narrower questions.</p>
      </div>

      <div class="card-grid card-grid--three card-grid--feature">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </section>
  ) : null
}
