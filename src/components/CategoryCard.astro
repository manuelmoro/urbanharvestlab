---
import type { CategoryDefinition } from '../data/categories';

import { getCategoryPath } from '../utils/seo';

interface Props {
  category: CategoryDefinition;
  count: number;
}

const { category, count } = Astro.props;
const titleParts = category.shortTitle.split(/[\s&]+/).filter(Boolean);
const initials =
  titleParts.length === 1
    ? titleParts[0].slice(0, 2).toUpperCase()
    : titleParts
        .map((part) => part[0])
        .join('')
        .slice(0, 2)
        .toUpperCase();
---

<a
  class="card category-card"
  href={getCategoryPath(category.slug)}
  style={`--category-accent: ${category.accent};`}
>
  <div class="category-card__top">
    <span class="category-card__mark" aria-hidden="true">{initials}</span>
    <span class="category-card__count">{count} {count === 1 ? 'guide' : 'guides'}</span>
  </div>

  <div class="category-card__content">
    <span class="category-card__label">Topic library</span>
    <h3>{category.title}</h3>
    <p>{category.summary}</p>
  </div>

  <span class="category-card__link">Explore topic</span>
</a>
