---
import { site } from '../data/site';
---

<section class="newsletter-block">
  <div>
    <span class="eyebrow">Stay in the loop</span>
    <h2>Get new guide alerts or send a topic request.</h2>
    <p>
      Email is the easiest way to suggest a topic, flag a correction, or ask about an upcoming guide.
    </p>
  </div>

  <div class="newsletter-actions" aria-label="Contact actions">
    <a class="button button--primary" href={`mailto:${site.email}`}>Email the team</a>
    <a class="button button--secondary" href="/blog/">Browse latest guides</a>
  </div>
</section>
