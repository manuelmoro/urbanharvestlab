---
import type { CollectionEntry } from 'astro:content';

import { categoryMap } from '../data/categories';
import { formatDate } from '../utils/format';
import { getImageMetadata } from '../utils/image-metadata.js';
import { getCategoryPath, getPostPath } from '../utils/seo';

interface Props {
  post: CollectionEntry<'blog'>;
  compact?: boolean;
}

const { post, compact = false } = Astro.props;
const category = categoryMap.get(post.data.category);
const excerpt = post.data.excerpt ?? post.data.description;
const postPath = getPostPath(post);
const categoryPath = getCategoryPath(post.data.category);
const imageMetadata = post.data.image ? getImageMetadata(post.data.image) : undefined;
---

<article class:list={['card', 'post-card', compact && 'post-card--compact']}>
  {
    post.data.image ? (
      <a class="post-card__media" href={postPath}>
        <img
          src={post.data.image}
          alt={post.data.imageAlt ?? ''}
          loading="lazy"
          decoding="async"
          width={imageMetadata?.width}
          height={imageMetadata?.height}
        />
      </a>
    ) : null
  }

  <div class="post-card__body">
    <div class="post-card__meta">
      <a class="pill" href={categoryPath} style={`--pill-accent: ${category?.accent ?? '#6f8763'};`}>
        {category?.shortTitle ?? 'Guide'}
      </a>
      <span class="post-card__date">{formatDate(post.data.publishDate)}</span>
    </div>

    <h3>
      <a href={postPath}>{post.data.title}</a>
    </h3>
    <p>{excerpt}</p>

    <div class="post-card__footer">
      <span class="post-card__author">{post.data.author}</span>
      <a class="post-card__cta" href={postPath}>Read guide</a>
    </div>
  </div>
</article>
