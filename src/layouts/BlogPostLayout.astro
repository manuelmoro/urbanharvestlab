---
import type { CollectionEntry } from 'astro:content';

import AuthorBox from '../components/AuthorBox.astro';
import BeginnerPath from '../components/BeginnerPath.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CalloutBox from '../components/CalloutBox.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import FAQBlock from '../components/FAQBlock.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import RelatedTopicLinks from '../components/RelatedTopicLinks.astro';
import TableOfContents from '../components/TableOfContents.astro';
import TroubleshootingPattern from '../components/TroubleshootingPattern.astro';
import BaseLayout from './BaseLayout.astro';
import { categoryMap } from '../data/categories';
import { site } from '../data/site';
import { formatDate } from '../utils/format';
import { getAbsoluteAssetUrl, getAbsoluteUrl, getCategoryPath, getPostPath } from '../utils/seo';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  post: CollectionEntry<'blog'>;
  Content: any;
  headings: Heading[];
  relatedPosts: CollectionEntry<'blog'>[];
  beginnerPathPosts: CollectionEntry<'blog'>[];
  topicLinksPosts: CollectionEntry<'blog'>[];
}

const { post, Content, headings, relatedPosts, beginnerPathPosts, topicLinksPosts } = Astro.props;
const category = categoryMap.get(post.data.category);
const siteBase = Astro.site ?? site.url;
const canonicalPath = getPostPath(post);
const articleUrl = getAbsoluteUrl(canonicalPath, siteBase);
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: category?.title ?? 'Category', href: getCategoryPath(post.data.category) },
  { label: post.data.title },
];
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    item: item.href ? getAbsoluteUrl(item.href, siteBase) : articleUrl,
  })),
};
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.publishDate).toISOString(),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': articleUrl,
  },
  articleSection: category?.title ?? 'Guides',
  author: {
    '@type': 'Organization',
    name: post.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
  },
  image: post.data.image ? getAbsoluteAssetUrl(post.data.image, siteBase) : undefined,
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  canonicalPath={canonicalPath}
  type="article"
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
  <Fragment slot="head">
    <meta property="article:published_time" content={post.data.publishDate.toISOString()} />
    <meta property="article:modified_time" content={(post.data.updatedDate ?? post.data.publishDate).toISOString()} />
    <meta property="article:author" content={post.data.author} />
  </Fragment>

  <section class="page-section page-section--narrow">
    <div class="container">
      <div class="post-header card">
        <Breadcrumbs items={breadcrumbItems} />

        <div class="post-header__meta">
          <span class="pill" style={`--pill-accent: ${category?.accent ?? '#6f8763'};`}>
            {category?.title ?? 'Guide'}
          </span>
          <span>{formatDate(post.data.publishDate)}</span>
          {post.data.updatedDate ? <span>Updated {formatDate(post.data.updatedDate)}</span> : null}
        </div>

        <h1>{post.data.title}</h1>
        <p class="post-header__excerpt">{post.data.excerpt ?? post.data.description}</p>

        <div class="post-header__byline">
          <span>{post.data.author}</span>
          <span>{post.data.tags.join(' · ')}</span>
        </div>

        {
          post.data.image ? (
            <div class="post-header__image">
              <img src={post.data.image} alt={post.data.imageAlt ?? ''} loading="eager" decoding="async" />
            </div>
          ) : null
        }
      </div>

      <div class="article-shell">
        <article class="article-main">
          {
            post.data.affiliate ? (
              <CalloutBox tone="warning" title="Affiliate disclosure">
                <p>
                  This guide may include affiliate links. If you buy through those links, Urban Harvest Lab may earn a
                  commission at no extra cost to you. Recommendations are still selected for fit, not payout.
                </p>
              </CalloutBox>
            ) : null
          }

          {
            post.data.keyTakeaways.length > 0 ? (
              <CalloutBox tone="takeaway" title="Key takeaways">
                <ul class="key-takeaways">
                  {post.data.keyTakeaways.map((item) => <li>{item}</li>)}
                </ul>
              </CalloutBox>
            ) : null
          }

          <BeginnerPath title={post.data.beginnerPathTitle} posts={beginnerPathPosts} />
          <TroubleshootingPattern diagnosis={post.data.diagnosis} />
          {post.data.comparisonTable ? <ComparisonTable table={post.data.comparisonTable} /> : null}

          <div class="post-prose">
            <Content />
          </div>

          <RelatedTopicLinks
            title={post.data.topicLinksTitle}
            description={post.data.topicLinksDescription}
            posts={topicLinksPosts}
          />
          <FAQBlock items={post.data.faq} />
          <AuthorBox author={site.author} />
          <RelatedArticles posts={relatedPosts} />
        </article>

        <aside class="article-aside">
          <TableOfContents headings={headings} />

          <div class="card aside-card">
            <p class="eyebrow">Topic hub</p>
            <h2>Go wider on {category?.shortTitle ?? 'this topic'}</h2>
            <p>
              Use the primary topic hub to move from this article into beginner pathways, setup guides, troubleshooting,
              and deeper evergreen coverage.
            </p>
            <a class="button button--secondary" href={getCategoryPath(post.data.category)}>Open topic hub</a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
